# =============================================================================
# File: .env.secret.example
# Path: infra/k8s/overlays/dev/.env.secret   (copy → .env.secret, fill values)
# Description: TEMPLATE for the dev overlay's Tier-2 Secret source. The
#              kustomize secretGenerator hashes this into the `aywizz-secrets`
#              Secret, injected into every pod via `envFrom`. Copy to
#              `.env.secret` (git-ignored) and fill REAL dev values.
#              CLAUDE.md §4.6 / R-100-118 v2.
#
#              Key SET (values omitted) — mirror to system-test/prod overlays
#              with their own values.
# =============================================================================

# Backend bootstrap admin (consumed by the *_init Jobs only).
ARANGO_ROOT_PASSWORD=
MINIO_ROOT_PASSWORD=

# App runtime credentials.
ARANGO_PASSWORD=
MINIO_SECRET_KEY=

# C2 — Auth Service.
C2_JWT_SECRET_KEY=
C2_LOCAL_ADMIN_PASSWORD=
C2_LOCAL_TENANT_MANAGER_PASSWORD=

# Production observability — workflow synthesis (R-100-124).
OBS_ELASTICSEARCH_PASSWORD=

# C8 — LLM gateway (LiteLLM proxy). NEW (V2 #1).
#   - ANTHROPIC_API_KEY : real provider key, read ONLY by the litellm pod.
#   - C8_GATEWAY_API_KEY : the shared gateway credential (clients + proxy
#     master_key). In dev it may instead be a placeholder in the overlay's
#     non-secret `.env` (configmap) ; in prod put the REAL value here.
ANTHROPIC_API_KEY=
C8_GATEWAY_API_KEY=
