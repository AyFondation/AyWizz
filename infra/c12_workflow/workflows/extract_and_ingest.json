        "url": "=http://c7:8000/api/v1/memory/projects/{{$('Webhook — POST /uploads/extract-and-ingest').item.json.project_id}}/sources/{{$('Webhook — POST /uploads/extract-and-ingest').item.json.source_id}}/ingest-chunks",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-User-Id", "value": "={{$('Webhook — POST /uploads/extract-and-ingest').item.json.uploaded_by || $('Webhook — POST /uploads/extract-and-ingest').item.json.user_id || 'system'}}" },
            { "name": "X-Tenant-Id", "value": "={{$('Webhook — POST /uploads/extract-and-ingest').item.json.tenant_id}}" },
            { "name": "X-User-Roles", "value": "project_editor,project_owner,admin" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
