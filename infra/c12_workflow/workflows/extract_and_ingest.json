    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Parse chunks.jsonl and the manifest into the ChunkIngestRequest\n// shape expected by C7's POST /ingest-chunks (R-400-223 v2).\nconst chunksRaw = $('MinIO GET chunks.jsonl').item.json.data\n  || $('MinIO GET chunks.jsonl').item.binary?.data\n  || $('MinIO GET chunks.jsonl').item.json;\nconst manifest = $('MinIO GET run_manifest.json').item.json;\nconst webhook = $('Webhook — POST /uploads/extract-and-ingest').item.json;\nconst runId = $('C13 POST /analyze').item.json.run_id;\n\n// chunks.jsonl is one JSON object per line.\nconst lines = (typeof chunksRaw === 'string' ? chunksRaw : '').split('\\n').filter(l => l.trim().length > 0);\nconst chunks = lines.map(l => JSON.parse(l));\n\nreturn {\n  json: {\n    extraction_run_id: runId,\n    manifest_object_key: `${webhook.tenant_id}/${webhook.project_id}/${webhook.source_id}/runs/${runId}/00_metadata/run_manifest.json`,\n    embedding_model: manifest.embedding_model || 'voyage-3',\n    embedding_model_version: manifest.embedding_model_version || '',\n    embedding_dimension: manifest.embedding_dimension || (chunks[0]?.embedding?.length || 0),\n    chunks,\n    uploaded_by: webhook.uploaded_by || webhook.user_id || 'system',\n    mime_type: webhook.mime_type || 'application/octet-stream'\n  }\n};"
      },
      "id": "build-c7-payload",
      "name": "Build C7 /ingest-chunks payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2260, 240],
      "notes": "Combines chunks.jsonl (text) + run_manifest.json (embedding model metadata) into the ChunkIngestRequest body for R-400-223 v2."
    },
