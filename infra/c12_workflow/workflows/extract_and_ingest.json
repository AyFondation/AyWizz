        "jsonBody": "={\n  \"tenant_id\": \"{{$('Webhook — POST /uploads/extract-and-ingest').item.json.tenant_id}}\",\n  \"project_id\": \"{{$('Webhook — POST /uploads/extract-and-ingest').item.json.project_id}}\",\n  \"source_id\": \"{{$('Webhook — POST /uploads/extract-and-ingest').item.json.source_id}}\",\n  \"raw_object_key\": \"{{$('Webhook — POST /uploads/extract-and-ingest').item.json.tenant_id}}/{{$('Webhook — POST /uploads/extract-and-ingest').item.json.project_id}}/{{$('Webhook — POST /uploads/extract-and-ingest').item.json.source_id}}/raw.{{$('Webhook — POST /uploads/extract-and-ingest').item.json.format}}\",\n  \"filename\": \"{{$('Webhook — POST /uploads/extract-and-ingest').item.json.filename}}\",\n  \"mime_type\": \"{{$('Webhook — POST /uploads/extract-and-ingest').item.json.mime_type || 'application/octet-stream'}}\",\n  \"format\": \"{{$('Webhook — POST /uploads/extract-and-ingest').item.json.format}}\",\n  \"quality_tier\": \"{{$('Webhook — POST /uploads/extract-and-ingest').item.json.quality_tier || 'minimal'}}\",\n  \"urgency\": \"{{$('Webhook — POST /uploads/extract-and-ingest').item.json.urgency || 'interactive'}}\",\n  \"document_type\": \"{{$('Webhook — POST /uploads/extract-and-ingest').item.json.document_type || 'report'}}\",\n  \"language\": null\n}",
